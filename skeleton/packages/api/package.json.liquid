{
    "name": "@{{project.name}}/api",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "devDependencies": {
        "@tsconfig/node26": "^26.0.0",
        "@types/node": "^25.9.1"
        {%- if features contains "postgres" %},
        "@mikro-orm/cli": "^7.1.3",
        "sql-formatter": "^15.8.0"
        {%- endif %}
    },
    "dependencies": {
        {%- if features contains "app-config" %}
        "@{{project.name}}/app-config": "workspace:*",
        {%- endif %}
        "dotenv": "^17.4.2",
        "logforth": "^1.3.0",
        "zod": "^4.4.3",
        "@jsonapi-serde/integration-taxum": "^1.4.3",
        "@jsonapi-serde/server": "^1.9.1",
        "@taxum/core": "^1.2.4"
        {%- if features contains "postgres" %},
        "@aws-sdk/client-secrets-manager": "^3.1061.0",
        "@mikro-orm/core": "^7.1.3",
        "@mikro-orm/decorators": "^7.1.3",
        "@mikro-orm/postgresql": "^7.1.3",
        "@mikro-orm/migrations": "^7.1.3",
        "@sindresorhus/fnv1a": "^3.1.0"
        {%- endif %}
        {%- if features contains "oauth2" %},
        "@taxum/jwt": "^1.1.5",
        "jose": "^6.2.3"
        {%- endif %}
    },
    "scripts": {
        "start": "tsx watch -C development --import=./src/register-crash-logger.ts ./src/index.ts",
        "typecheck": "tsc --noEmit",
        "build": "tsc"
        {%- if features contains "postgres" %},
        "mikro-orm": "tsx -C development ./node_modules/@mikro-orm/cli/esm"
        {%- endif %}
    }
    {%- if features contains "postgres" %},
    "mikro-orm": {
        "configPaths": ["./src/mikro-orm.config.ts", "./mikro-orm.config.js"]
    }
    {%- endif %}
}
