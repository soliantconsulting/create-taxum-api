{
    "extends": ["@tsconfig/node26/tsconfig.json"],
    "compilerOptions": {
        "strict": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "types": ["node"],
        "rootDir": "src",
        "outDir": "dist"
        {%- if features contains "postgres" %},
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
        {%- endif %}
    },
    "include": ["src/**/*"]
}
